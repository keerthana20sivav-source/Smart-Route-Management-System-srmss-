<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SRMSS — Schedule Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #f5f0eb; font-family: 'Segoe UI', sans-serif; }
    .sri-lanka-stripes { position: fixed; top: 0; left: 0; width: 100%; height: 6px; display: flex; z-index: 1050; }
    .stripe { flex: 1; height: 100%; }
    .stripe-maroon { background: #8B1A1A; } .stripe-gold { background: #FFD700; } .stripe-green { background: #006633; } .stripe-orange { background: #FF6600; }
    .sidebar { width: 260px; height: 100vh; background: linear-gradient(180deg, #8B1A1A 0%, #6B1010 100%); position: fixed; top: 6px; left: 0; padding: 20px 0; color: white; z-index: 1040; overflow-y: auto; box-shadow: 4px 0 20px rgba(139,26,26,0.2); }
    .sidebar-brand { font-size: 22px; font-weight: 800; padding: 0 20px 18px 20px; border-bottom: 2px solid rgba(255,215,0,0.3); display: flex; align-items: center; gap: 10px; color: #FFD700; }
    .sidebar-section { padding: 12px 20px 6px 20px; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4); }
    .sidebar a { display: flex; align-items: center; gap: 12px; padding: 11px 20px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 14px; font-weight: 500; border-left: 3px solid transparent; }
    .sidebar a:hover, .sidebar a.active { background: rgba(255,215,0,0.15); color: #FFD700; border-left-color: #FFD700; }
    .sidebar a.logout-link { margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; color: rgba(255,150,150,0.8); }
    .sidebar .sri-badge { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px 16px; margin: 12px 16px 0 16px; background: rgba(255,215,0,0.15); border-radius: 20px; font-size: 11px; color: #FFD700; }
    .main { margin-left: 260px; padding: 30px; margin-top: 6px; }
    .topbar { background: white; padding: 16px 24px; border-radius: 16px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(139,26,26,0.08); border-left: 4px solid #8B1A1A; }
    .topbar h5 { font-weight: 700; color: #3a2a22; margin: 0; }
    .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #8B1A1A, #A02020); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; }
    .card-custom { background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(139,26,26,0.06); border-top: 4px solid #8B1A1A; margin-bottom: 20px; }
    .section-title { font-weight: 700; color: #3a2a22; font-size: 15px; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 2px solid #f5f0eb; }
    .section-title i { color: #8B1A1A; margin-right: 8px; }
    .info-row { display: flex; gap: 8px; margin-bottom: 10px; align-items: flex-start; }
    .info-label { font-size: 12px; color: #8a7a6e; font-weight: 600; min-width: 130px; }
    .info-value { font-size: 14px; color: #3a2a22; font-weight: 500; }
    .stat-mini { background: #faf7f5; border-radius: 12px; padding: 16px; text-align: center; }
    .stat-mini .val { font-size: 24px; font-weight: 800; color: #8B1A1A; }
    .stat-mini .lbl { font-size: 12px; color: #8a7a6e; margin-top: 2px; }
    .badge-scheduled { background: #e8f5ee; color: #006633; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-cancelled { background: #fdf2ee; color: #8B1A1A; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-emergency { background: #fff3e0; color: #FF6600; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-completed { background: #e8f0fe; color: #1a56db; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .trip-badge-ontime { background: #e8f5ee; color: #006633; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .trip-badge-delayed { background: #fff3e0; color: #FF6600; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .trip-badge-completed { background: #e8f0fe; color: #1a56db; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .trip-badge-cancelled { background: #fdf2ee; color: #8B1A1A; padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .table thead th { background: #faf7f5; color: #5a4a3a; font-weight: 600; font-size: 12px; text-transform: uppercase; padding: 10px 16px; border-bottom: 2px solid #f5f0eb; }
    .table tbody td { padding: 10px 16px; font-size: 13px; border-bottom: 1px solid #f5f0eb; vertical-align: middle; }
    .route-flow { display: flex; align-items: center; gap: 10px; background: #faf7f5; border-radius: 10px; padding: 12px 16px; margin-bottom: 16px; }
    .route-flow .point { font-weight: 700; font-size: 14px; }
    .route-flow .arrow { color: #b5a69a; font-size: 18px; }
    .btn-edit { background: linear-gradient(135deg, #FFD700, #F0C000); color: #3a2a22; border: none; border-radius: 10px; padding: 8px 20px; font-weight: 600; text-decoration: none; font-size: 13px; }
    .btn-back { border-radius: 10px; border: 2px solid #eddfd7; color: #5a4a3a; padding: 8px 16px; text-decoration: none; font-size: 13px; }
  </style>
</head>
<body>

  <div class="sri-lanka-stripes">
    <div class="stripe stripe-maroon"></div><div class="stripe stripe-gold"></div>
    <div class="stripe stripe-green"></div><div class="stripe stripe-orange"></div>
    <div class="stripe stripe-maroon"></div>
  </div>

  <div class="sidebar">
    <div class="sidebar-brand"><i class="fas fa-bus"></i><span>SRMSS</span></div>
    <div class="sidebar-section">Main Menu</div>
    <a href="/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
    <a href="/routes"><i class="fas fa-route"></i><span>Routes</span></a>
    <a href="/schedules" class="active"><i class="fas fa-calendar-alt"></i><span>Schedules</span></a>
    <a href="/routes/map"><i class="fas fa-map"></i><span>Map View</span></a>
    <div class="sidebar-section">Management</div>
    <a href="/buses"><i class="fas fa-bus-alt"></i><span>Buses</span></a>
    <a href="/drivers"><i class="fas fa-id-card"></i><span>Drivers</span></a>
    <a href="/fuel"><i class="fas fa-gas-pump"></i><span>Fuel Logs</span></a>
    <a href="/maintenance"><i class="fas fa-wrench"></i><span>Maintenance</span></a>
    <div class="sidebar-section">Analytics</div>
    <a href="/reports"><i class="fas fa-file-alt"></i><span>Reports</span></a>
    <a href="/users"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
    <div class="sri-badge"><i class="fas fa-flag"></i>Sri Lanka</div>
  </div>

  <div class="main">
    <div class="topbar">
      <h5>
        <i class="fas fa-calendar-alt" style="color:#8B1A1A; margin-right:8px;"></i>
        Schedule Details
        <span style="background:#fdf2ee; color:#8B1A1A; padding:4px 14px; border-radius:20px; font-size:13px; font-weight:600; margin-left:8px;">
          #<%= schedule.schedule_id %>
        </span>
        <% if(schedule.status === 'scheduled') { %>
          <span class="badge-scheduled ms-2">🟢 Scheduled</span>
        <% } else if(schedule.status === 'cancelled') { %>
          <span class="badge-cancelled ms-2">🔴 Cancelled</span>
        <% } else if(schedule.status === 'emergency') { %>
          <span class="badge-emergency ms-2">🟠 Emergency</span>
        <% } else if(schedule.status === 'completed') { %>
          <span class="badge-completed ms-2">🔵 Completed</span>
        <% } %>
      </h5>
      <div class="d-flex align-items-center gap-2">
        <div class="user-avatar"><%= user.full_name.charAt(0).toUpperCase() %></div>
        <a href="/schedules" class="btn-back">
          <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <% if(user.role !== 'supervisor') { %>
          <a href="/schedules/edit/<%= schedule.schedule_id %>" class="btn-edit">
            <i class="fas fa-pen me-1"></i>Edit
          </a>
        <% } %>
      </div>
    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">
      <div class="col-md-3 col-6">
        <div class="stat-mini">
          <div class="val"><%= trips.length %></div>
          <div class="lbl">Total Trips</div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-mini">
          <div class="val" style="color:#006633;">
            <%= trips.filter(t => t.status === 'on_time').length %>
          </div>
          <div class="lbl">On Time</div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-mini">
          <div class="val" style="color:#FF6600;">
            <%= trips.filter(t => t.status === 'delayed').length %>
          </div>
          <div class="lbl">Delayed</div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="stat-mini">
          <div class="val" style="color:#1a56db;">
            <%= trips.filter(t => t.status === 'completed').length %>
          </div>
          <div class="lbl">Completed</div>
        </div>
      </div>
    </div>

    <div class="row g-4">

      <!-- LEFT — Schedule Info -->
      <div class="col-md-5">

        <!-- Route Info -->
        <div class="card-custom">
          <div class="section-title"><i class="fas fa-route"></i>Route Information</div>
          <% if(schedule.route_name) { %>
            <div class="route-flow mb-3">
              <div class="point" style="color:#8B1A1A;"><i class="fas fa-location-dot me-1"></i><%= schedule.start_point || 'N/A' %></div>
              <div class="arrow">→</div>
              <div class="point" style="color:#006633;"><i class="fas fa-location-dot me-1"></i><%= schedule.end_point || 'N/A' %></div>
            </div>
          <% } %>
          <div class="info-row">
            <span class="info-label"><i class="fas fa-route me-1"></i>Route</span>
            <span class="info-value"><%= schedule.route_name || 'N/A' %></span>
          </div>
          <div class="info-row">
            <span class="info-label"><i class="fas fa-ruler me-1"></i>Distance</span>
            <span class="info-value"><%= schedule.distance_km || 'N/A' %> km</span>
          </div>
          <div class="info-row">
            <span class="info-label"><i class="fas fa-clock me-1"></i>Departure</span>
            <span class="info-value" style="color:#8B1A1A; font-weight:700;">
              <%= schedule.departure_time ? new Date(schedule.departure_time).toLocaleString('en-LK') : 'N/A' %>
            </span>
          </div>
          <div class="info-row">
            <span class="info-label"><i class="fas fa-clock me-1"></i>Arrival</span>
            <span class="info-value" style="color:#006633; font-weight:700;">
              <%= schedule.arrival_time ? new Date(schedule.arrival_time).toLocaleString('en-LK') : 'N/A' %>
            </span>
          </div>
          <div class="info-row">
            <span class="info-label"><i class="fas fa-repeat me-1"></i>Type</span>
            <span class="info-value">
              <% const typeMap = {daily:'📅 Daily', weekly:'📆 Weekly', monthly:'📋 Monthly', maintenance_work:'🔧 Maintenance Work', unexpected_event:'⚡ Unexpected Event', special_event:'🎉 Special Event'}; %>
              <%= typeMap[schedule.schedule_type] || schedule.schedule_type %>
            </span>
          </div>
        </div>

        <!-- Bus Info -->
        <div class="card-custom">
          <div class="section-title"><i class="fas fa-bus-alt"></i>Bus Information</div>
          <% if(schedule.registration_no) { %>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-hashtag me-1"></i>Registration</span>
              <span class="info-value" style="font-weight:700; color:#8B1A1A;"><%= schedule.registration_no %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-car me-1"></i>Model</span>
              <span class="info-value"><%= schedule.model || 'N/A' %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-users me-1"></i>Capacity</span>
              <span class="info-value"><%= schedule.seating_capacity || 'N/A' %> seats</span>
            </div>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-gas-pump me-1"></i>Fuel Type</span>
              <span class="info-value"><%= schedule.fuel_type || 'N/A' %></span>
            </div>
          <% } else { %>
            <div class="text-muted" style="font-size:13px; text-align:center; padding:16px;">
              <i class="fas fa-bus" style="font-size:28px; color:#eddfd7; display:block; margin-bottom:8px;"></i>
              No bus assigned
            </div>
          <% } %>
        </div>

        <!-- Driver Info -->
        <div class="card-custom">
          <div class="section-title"><i class="fas fa-id-card"></i>Driver Information</div>
          <% if(schedule.driver_name) { %>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-user me-1"></i>Name</span>
              <span class="info-value" style="font-weight:700;"><%= schedule.driver_name %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-phone me-1"></i>Phone</span>
              <span class="info-value"><%= schedule.driver_phone || 'N/A' %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-id-card me-1"></i>License No</span>
              <span class="info-value"><%= schedule.license_no || 'N/A' %></span>
            </div>
            <div class="info-row">
              <span class="info-label"><i class="fas fa-calendar me-1"></i>License Expiry</span>
              <span class="info-value" style="color:<%= schedule.license_expiry && new Date(schedule.license_expiry) < new Date() ? '#dc3545' : '#006633' %>; font-weight:600;">
                <%= schedule.license_expiry ? new Date(schedule.license_expiry).toLocaleDateString() : 'N/A' %>
              </span>
            </div>
          <% } else { %>
            <div class="text-muted" style="font-size:13px; text-align:center; padding:16px;">
              <i class="fas fa-id-card" style="font-size:28px; color:#eddfd7; display:block; margin-bottom:8px;"></i>
              No driver assigned
            </div>
          <% } %>
        </div>

      </div>

      <!-- RIGHT — Trip History -->
      <div class="col-md-7">
        <div class="card-custom">
          <div class="section-title"><i class="fas fa-history"></i>Trip History</div>
          <% if(trips.length === 0) { %>
            <div class="text-center text-muted py-5">
              <i class="fas fa-route" style="font-size:40px; color:#eddfd7; display:block; margin-bottom:10px;"></i>
              No trips recorded yet
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Actual Departure</th>
                    <th>Status</th>
                    <th>Recorded</th>
                  </tr>
                </thead>
                <tbody>
                  <% trips.forEach((t, i) => { %>
                  <tr>
                    <td><strong><%= i + 1 %></strong></td>
                    <td style="font-size:12px;">
                      <%= t.actual_departure ? new Date(t.actual_departure).toLocaleString('en-LK') : 'N/A' %>
                    </td>
                    <td>
                      <% if(t.status === 'on_time') { %>
                        <span class="trip-badge-ontime">✅ On Time</span>
                      <% } else if(t.status === 'delayed') { %>
                        <span class="trip-badge-delayed">⚠️ Delayed</span>
                      <% } else if(t.status === 'completed') { %>
                        <span class="trip-badge-completed">🔵 Completed</span>
                      <% } else if(t.status === 'cancelled') { %>
                        <span class="trip-badge-cancelled">❌ Cancelled</span>
                      <% } else { %>
                        <span><%= t.status %></span>
                      <% } %>
                    </td>
                    <td style="font-size:11px; color:#8a7a6e;">
                      <%= t.created_at ? new Date(t.created_at).toLocaleString('en-LK') : 'N/A' %>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

    </div>

    <div class="text-center mt-4" style="font-size:12px; color:#b5a69a;">
      <i class="fas fa-shield-alt me-1"></i> SRMSS v1.0 • <i class="fas fa-heart" style="color:#8B1A1A;"></i> Made in Sri Lanka
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
