<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SRMSS — Schedules</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #f5f0eb; font-family: 'Segoe UI', sans-serif; }
    .sri-lanka-stripes { position: fixed; top: 0; left: 0; width: 100%; height: 6px; display: flex; z-index: 1050; }
    .stripe { flex: 1; height: 100%; }
    .stripe-maroon { background: #8B1A1A; } .stripe-gold { background: #FFD700; } .stripe-green { background: #006633; } .stripe-orange { background: #FF6600; } .stripe-maroon2 { background: #8B1A1A; }
    .sidebar { width: 260px; height: 100vh; background: linear-gradient(180deg, #8B1A1A 0%, #6B1010 100%); position: fixed; top: 6px; left: 0; padding: 20px 0; color: white; z-index: 1040; overflow-y: auto; box-shadow: 4px 0 20px rgba(139,26,26,0.2); }
    .sidebar-brand { font-size: 22px; font-weight: 800; padding: 0 20px 18px 20px; border-bottom: 2px solid rgba(255,215,0,0.3); display: flex; align-items: center; gap: 10px; color: #FFD700; }
    .sidebar-brand span { color: white; } .sidebar-brand i { font-size: 28px; }
    .sidebar-section { padding: 12px 20px 6px 20px; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4); }
    .sidebar a { display: flex; align-items: center; gap: 12px; padding: 11px 20px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 14px; font-weight: 500; border-left: 3px solid transparent; }
    .sidebar a i { width: 20px; text-align: center; font-size: 16px; }
    .sidebar a:hover, .sidebar a.active { background: rgba(255,215,0,0.15); color: #FFD700; border-left-color: #FFD700; }
    .sidebar a.logout-link { margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; color: rgba(255,150,150,0.8); }
    .sidebar .sri-badge { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px 16px; margin: 12px 16px 0 16px; background: rgba(255,215,0,0.15); border-radius: 20px; font-size: 11px; color: #FFD700; }
    .main { margin-left: 260px; padding: 30px; margin-top: 6px; }
    .topbar { background: white; padding: 16px 24px; border-radius: 16px; margin-bottom: 28px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(139,26,26,0.08); border-left: 4px solid #8B1A1A; }
    .topbar h5 { font-weight: 700; color: #3a2a22; }
    .topbar .user-info { display: flex; align-items: center; gap: 12px; }
    .topbar .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #8B1A1A, #A02020); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .stats-badge { background: #fdf2ee; color: #8B1A1A; padding: 4px 14px; border-radius: 20px; font-size: 13px; font-weight: 600; }
    .btn-add { background: linear-gradient(135deg, #8B1A1A, #A02020); color: white; border: none; border-radius: 10px; padding: 8px 20px; font-weight: 600; font-size: 14px; }
    .btn-add:hover { color: white; background: #7a1515; }
    .btn-sm-outline { border-radius: 8px; padding: 4px 8px; font-size: 12px; border: 2px solid #eddfd7; background: transparent; }
    .btn-sm-outline.edit { color: #8B1A1A; }
    .btn-sm-outline.edit:hover { background: #fdf2ee; border-color: #8B1A1A; }
    .btn-sm-outline.delete { color: #dc3545; }
    .btn-sm-outline.delete:hover { background: #fdf2ee; border-color: #dc3545; }
    .btn-sm-outline.emergency { color: #FF6600; }
    .btn-sm-outline.emergency:hover { background: #fdf0e6; border-color: #FF6600; }
    .card-custom { background: white; border-radius: 16px; padding: 0; box-shadow: 0 4px 20px rgba(139,26,26,0.06); border-top: 4px solid #8B1A1A; overflow: hidden; }
    .card-header-custom { padding: 18px 24px; background: #faf7f5; border-bottom: 2px solid #f5f0eb; display: flex; justify-content: space-between; align-items: center; }
    .card-header-custom h6 { font-weight: 700; color: #3a2a22; margin: 0; }
    .table { margin-bottom: 0; }
    .table thead th { background: #faf7f5; color: #5a4a3a; font-weight: 600; font-size: 11px; text-transform: uppercase; padding: 12px 16px; border-bottom: 2px solid #f5f0eb; white-space: nowrap; }
    .table tbody td { padding: 10px 16px; vertical-align: middle; font-size: 13px; border-bottom: 1px solid #f5f0eb; }
    .table tbody tr:hover { background: #fdfaf8; }
    .badge-scheduled { background: #e8f5ee; color: #006633; padding: 4px 14px; border-radius: 20px; font-weight: 600; font-size: 12px; }
    .badge-cancelled { background: #fdf2ee; color: #8B1A1A; padding: 4px 14px; border-radius: 20px; font-weight: 600; font-size: 12px; }
    .badge-emergency { background: #fff3cd; color: #856404; padding: 4px 14px; border-radius: 20px; font-weight: 600; font-size: 12px; border: 1px solid #ffc107; }
    .badge-completed { background: #e8f0fe; color: #1a56db; padding: 4px 14px; border-radius: 20px; font-weight: 600; font-size: 12px; }
    .badge-type { background: #faf7f5; color: #5a4a3a; padding: 2px 12px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .empty-state { padding: 40px 20px; text-align: center; color: #b5a69a; }
    .empty-state i { font-size: 48px; margin-bottom: 12px; display: block; color: #eddfd7; }
    .emergency-alert { background: #fdf0e6; border-left: 4px solid #FF6600; border-radius: 10px; padding: 12px 20px; margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }
    .table-warning { background: #fdf0e6 !important; }
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.6; } }
    @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
  </style>
</head>
<body>

  <div class="sri-lanka-stripes">
    <div class="stripe stripe-maroon"></div><div class="stripe stripe-gold"></div>
    <div class="stripe stripe-green"></div><div class="stripe stripe-orange"></div>
    <div class="stripe stripe-maroon2"></div>
  </div>

  <div class="sidebar">
    <div class="sidebar-brand"><i class="fas fa-bus"></i><span>SRM<span class="brand-text">SS</span></span></div>
    <div class="sidebar-section">Main Menu</div>
    <a href="/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
    <a href="/routes"><i class="fas fa-route"></i><span>Routes</span></a>
    <a href="/schedules" class="active"><i class="fas fa-calendar-alt"></i><span>Schedules</span></a>
    <a href="/routes/map"><i class="fas fa-map"></i><span>Map View</span></a>
    <div class="sidebar-section">Management</div>
    <a href="/buses"><i class="fas fa-bus-alt"></i><span>Buses</span></a>
    <a href="/drivers"><i class="fas fa-id-card"></i><span>Drivers</span></a>
    <a href="/fuel"><i class="fas fa-gas-pump"></i><span>Fuel Logs</span></a>
    <a href="/maintenance"><i class="fas fa-wrench"></i><span>Maintenance</span></a>
    <div class="sidebar-section">Analytics</div>
    <a href="/reports"><i class="fas fa-file-alt"></i><span>Reports</span></a>
    <a href="/users"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
    <div class="sri-badge"><i class="fas fa-flag"></i>Sri Lanka</div>
  </div>

  <% const emergencyCount = schedules.filter(s => s.status === 'emergency').length; %>

  <div class="main">
    <div class="topbar">
      <h5>
        <i class="fas fa-calendar-alt" style="color:#8B1A1A; margin-right:8px;"></i>Schedule Management
        <span class="stats-badge ms-2"><i class="fas fa-list me-1"></i><%= schedules.length %> Schedules</span>
        <% if(emergencyCount > 0) { %>
          <span class="badge ms-2" style="background:#FF6600; color:white; padding:4px 14px; border-radius:20px; font-size:12px; animation:pulse 1.5s infinite;">
            <i class="fas fa-triangle-exclamation"></i> <%= emergencyCount %> Emergency
          </span>
        <% } %>
      </h5>
      <div class="d-flex align-items-center gap-3">
        <div class="user-info">
          <div class="user-avatar"><%= user ? user.full_name.charAt(0).toUpperCase() : 'A' %></div>
          <span style="font-weight:600; color:#3a2a22;"><%= user ? user.full_name : 'Admin' %></span>
        </div>
        <a href="/schedules/add" class="btn-add btn"><i class="fas fa-plus-circle"></i> Add Schedule</a>
      </div>
    </div>

    <% if(emergencyCount > 0) { %>
      <div class="emergency-alert">
        <div>
          <span style="color:#FF6600; font-size:20px; margin-right:12px;"><i class="fas fa-triangle-exclamation"></i></span>
          <span style="color:#5a4a3a; font-weight:500;">
            <strong style="color:#FF6600;"><%= emergencyCount %> Emergency Schedule(s) Active!</strong>
            Click <strong>"Resolve Emergency"</strong> to clear all.
          </span>
        </div>
        <a href="/schedules/clear-emergency" style="background:#FF6600; color:white; border:none; border-radius:8px; padding:6px 16px; font-weight:600; font-size:12px; text-decoration:none;" onclick="return confirm('Clear all emergency schedules?')">
          <i class="fas fa-check-circle"></i> Resolve Emergency
        </a>
      </div>
    <% } %>

    <div class="card-custom">
      <div class="card-header-custom">
        <h6><i class="fas fa-table" style="color:#8B1A1A; margin-right:8px;"></i>All Schedules</h6>
        <div style="font-size:11px; color:#8a7a6e;">
          <i class="fas fa-circle" style="color:#006633; font-size:8px;"></i> Scheduled &nbsp;
          <i class="fas fa-circle" style="color:#8B1A1A; font-size:8px;"></i> Cancelled &nbsp;
          <i class="fas fa-circle" style="color:#FF6600; font-size:8px; animation:blink 1s infinite;"></i> Emergency &nbsp;
          <i class="fas fa-circle" style="color:#1a56db; font-size:8px;"></i> Completed
        </div>
      </div>

      <div style="overflow-x:auto; padding:0 4px 4px 4px;">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>#</th>
              <th>Route</th>
              <th>Bus</th>
              <th>Driver</th>
              <th>Departure</th>
              <th>Arrival</th>
              <th>Type</th>
              <th>Status</th>
              <th>Trip Status</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if(schedules.length === 0) { %>
              <tr><td colspan="10">
                <div class="empty-state">
                  <i class="fas fa-calendar-alt"></i>
                  <h6>No Schedules Found</h6>
                  <p style="font-size:14px;">Click "Add Schedule" to create your first schedule.</p>
                </div>
              </td></tr>
            <% } else { %>
              <% schedules.forEach((s, index) => { %>
              <tr class="<%= s.status === 'emergency' ? 'table-warning' : '' %>">
                <td><strong><%= index + 1 %></strong></td>
                <td>
                  <span style="font-weight:600;">
                    <i class="fas fa-route" style="color:#8B1A1A;"></i> <%= s.route_name || 'N/A' %>
                  </span>
                  <% if(s.status === 'emergency') { %>
                    <span class="badge" style="background:#FF6600; color:white; font-size:9px; padding:1px 8px; border-radius:10px; margin-left:4px;">
                      <i class="fas fa-bolt"></i> PRIORITY
                    </span>
                  <% } %>
                </td>
                <td>
                  <% if(s.registration_no) { %>
                    <span style="background:#faf7f5; padding:2px 10px; border-radius:12px; font-size:12px;">
                      <i class="fas fa-bus-alt" style="color:#8B1A1A;"></i> <%= s.registration_no %>
                    </span>
                  <% } else { %><span style="color:#b5a69a;">—</span><% } %>
                </td>
                <td>
                  <% if(s.driver_name) { %>
                    <span style="background:#faf7f5; padding:2px 10px; border-radius:12px; font-size:12px;">
                      <i class="fas fa-user" style="color:#8B1A1A;"></i> <%= s.driver_name %>
                    </span>
                  <% } else { %><span style="color:#b5a69a;">—</span><% } %>
                </td>
                <td style="font-size:12px;">
                  <i class="fas fa-clock" style="color:#8B1A1A;"></i>
                  <%= s.departure_time ? new Date(s.departure_time).toLocaleString() : 'N/A' %>
                </td>
                <td style="font-size:12px;">
                  <i class="fas fa-clock" style="color:#006633;"></i>
                  <%= s.arrival_time ? new Date(s.arrival_time).toLocaleString() : 'N/A' %>
                </td>
                <td>
                  <span class="badge-type">
                    <i class="fas fa-<%= s.schedule_type === 'daily' ? 'sun' : s.schedule_type === 'weekly' ? 'calendar-week' : 'calendar' %>"></i>
                    <%= s.schedule_type %>
                  </span>
                </td>
                <td>
                  <% if(s.status === 'scheduled') { %>
                    <span class="badge-scheduled"><i class="fas fa-circle" style="font-size:8px;"></i> Scheduled</span>
                  <% } else if(s.status === 'cancelled') { %>
                    <span class="badge-cancelled"><i class="fas fa-circle" style="font-size:8px;"></i> Cancelled</span>
                  <% } else if(s.status === 'emergency') { %>
                    <span class="badge-emergency" style="animation:pulse 1.5s infinite;">
                      <i class="fas fa-triangle-exclamation" style="font-size:10px;"></i> Emergency
                    </span>
                  <% } else { %>
                    <span class="badge-completed"><i class="fas fa-circle" style="font-size:8px;"></i> Completed</span>
                  <% } %>
                </td>

                <td>
                  <%
                    let tripLabel = 'Trip';
                    let tripColor = '#3a2a22';
                    let tripBorder = '#eddfd7';
                    if(s.last_trip_status === 'on_time') { tripLabel = '✅ On Time'; tripColor = '#006633'; tripBorder = '#006633'; }
                    else if(s.last_trip_status === 'delayed') { tripLabel = '⚠️ Delayed'; tripColor = '#FF6600'; tripBorder = '#FF6600'; }
                    else if(s.last_trip_status === 'completed') { tripLabel = '🔵 Completed'; tripColor = '#1a56db'; tripBorder = '#1a56db'; }
                    else if(s.last_trip_status === 'cancelled') { tripLabel = '❌ Cancelled'; tripColor = '#dc3545'; tripBorder = '#dc3545'; }
                  %>
                  <div class="dropdown">
                    <button class="btn btn-sm dropdown-toggle"
                            id="tripBtn<%= s.schedule_id %>"
                            style="background:#faf7f5; border:2px solid <%= tripBorder %>; color:<%= tripColor %>; border-radius:8px; font-size:12px; padding:4px 10px;"
                            type="button" data-bs-toggle="dropdown">
                      <i class="fas fa-bolt" style="color:#8B1A1A;"></i>
                      <span id="tripLabel<%= s.schedule_id %>"><%= tripLabel %></span>
                    </button>
                    <ul class="dropdown-menu" style="border-radius:12px; border:2px solid #eddfd7; min-width:160px; padding:6px;">
                      <li>
                        <a class="dropdown-item" href="#"
                           onclick="selectTrip(<%= s.schedule_id %>, 'ontime', '✅ On Time', '#006633'); return false;"
                           style="border-radius:8px; font-size:13px; padding:8px 12px;">
                          <i class="fas fa-check-circle" style="color:#006633;"></i> On Time
                        </a>
                      </li>
                      <li>
                        <a class="dropdown-item" href="#"
                           onclick="selectTrip(<%= s.schedule_id %>, 'delayed', '⚠️ Delayed', '#FF6600'); return false;"
                           style="border-radius:8px; font-size:13px; padding:8px 12px;">
                          <i class="fas fa-clock" style="color:#FF6600;"></i> Delayed
                        </a>
                      </li>
                      <li>
                        <a class="dropdown-item" href="#"
                           onclick="selectTrip(<%= s.schedule_id %>, 'completed', '🔵 Completed', '#1a56db'); return false;"
                           style="border-radius:8px; font-size:13px; padding:8px 12px;">
                          <i class="fas fa-flag-checkered" style="color:#1a56db;"></i> Completed
                        </a>
                      </li>
                      <li><hr class="dropdown-divider" style="margin:4px 0;"></li>
                      <li>
                        <a class="dropdown-item" href="#"
                           onclick="selectTrip(<%= s.schedule_id %>, 'cancelled', '❌ Cancelled', '#dc3545'); return false;"
                           style="border-radius:8px; font-size:13px; padding:8px 12px; color:#dc3545;">
                          <i class="fas fa-times-circle"></i> Cancelled
                        </a>
                      </li>
                    </ul>
                  </div>
                  <div id="confirmDiv<%= s.schedule_id %>" style="display:none; margin-top:4px;">
                    <a id="confirmBtn<%= s.schedule_id %>" href="#"
                       style="background:#8B1A1A; color:white; border-radius:8px; padding:4px 12px; font-size:12px; text-decoration:none; font-weight:600;">
                      <i class="fas fa-save me-1"></i>Save
                    </a>
                    <a href="#" onclick="cancelTrip(<%= s.schedule_id %>); return false;"
                       style="color:#8a7a6e; font-size:12px; margin-left:6px;">Cancel</a>
                  </div>
                </td>

                <td class="text-center">
  <div class="d-flex align-items-center justify-content-center gap-1">
    <a href="/schedules/view/<%= s.schedule_id %>" class="btn-sm-outline" style="color:#1a56db;" title="View">
      <i class="fas fa-eye"></i>
    </a>
    <a href="/schedules/edit/<%= s.schedule_id %>" class="btn-sm-outline edit" title="Edit">
      <i class="fas fa-pen"></i>
    </a>
    <% if(s.status === 'emergency') { %>
      <a href="/schedules/resolve/<%= s.schedule_id %>" class="btn-sm-outline emergency" title="Resolve">
        <i class="fas fa-check-circle"></i>
      </a>
    <% } %>
    <a href="/schedules/delete/<%= s.schedule_id %>" class="btn-sm-outline delete"
       onclick="return confirm('Delete this schedule?')" title="Delete">
      <i class="fas fa-trash"></i>
    </a>
  </div>
</td>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="text-center mt-4" style="font-size:12px; color:#b5a69a;">
      <i class="fas fa-shield-alt me-1"></i> SRMSS v1.0 • <i class="fas fa-heart" style="color:#8B1A1A;"></i> Made in Sri Lanka
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function selectTrip(scheduleId, status, label, color) {
      const btn = document.getElementById('tripBtn' + scheduleId);
      const labelEl = document.getElementById('tripLabel' + scheduleId);
      const confirmDiv = document.getElementById('confirmDiv' + scheduleId);
      const confirmBtn = document.getElementById('confirmBtn' + scheduleId);

      labelEl.textContent = label;
      btn.style.borderColor = color;
      btn.style.color = color;
      confirmBtn.href = '/schedules/trip/' + status + '/' + scheduleId;
      confirmDiv.style.display = 'block';
    }

    function cancelTrip(scheduleId) {
      const btn = document.getElementById('tripBtn' + scheduleId);
      const labelEl = document.getElementById('tripLabel' + scheduleId);
      const confirmDiv = document.getElementById('confirmDiv' + scheduleId);
      labelEl.textContent = 'Trip';
      btn.style.borderColor = '#eddfd7';
      btn.style.color = '#3a2a22';
      confirmDiv.style.display = 'none';
    }
  </script>
</body>
</html>
