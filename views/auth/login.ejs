<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SRMSS — Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    /* ===== GLOBAL ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #f5f0eb;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-image: radial-gradient(circle at 10% 30%, #fff5f0 0%, #f5e6dc 100%);
      position: relative;
    }

    /* ===== SRI LANKAN FLAG STRIPES ===== */
    .sri-lanka-stripes {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 8px;
      display: flex;
      z-index: 1000;
    }
    .stripe {
      flex: 1;
      height: 100%;
    }
    .stripe-maroon { background: #8B1A1A; }
    .stripe-gold { background: #FFD700; }
    .stripe-green { background: #006633; }
    .stripe-orange { background: #FF6600; }
    .stripe-maroon2 { background: #8B1A1A; }

    /* ===== LOGIN CARD ===== */
    .login-card {
      background: white;
      border-radius: 20px;
      padding: 45px 40px 40px 40px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 20px 60px rgba(139, 26, 26, 0.15);
      border-top: 6px solid #8B1A1A;
      position: relative;
      animation: slideUp 0.6s ease;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ===== LOGO ===== */
    .logo-wrapper {
      text-align: center;
      margin-bottom: 28px;
    }
    .logo-icon {
      font-size: 48px;
      color: #8B1A1A;
      background: #fdf2ee;
      width: 80px;
      height: 80px;
      line-height: 80px;
      border-radius: 50%;
      display: inline-block;
      margin-bottom: 8px;
      box-shadow: 0 4px 12px rgba(139, 26, 26, 0.15);
    }
    .logo-title {
      font-size: 28px;
      font-weight: 800;
      color: #8B1A1A;
      letter-spacing: 1px;
    }
    .logo-title span {
      color: #FFD700;
    }
    .logo-sub {
      font-size: 13px;
      color: #8a7a6e;
      letter-spacing: 2px;
      font-weight: 500;
      margin-top: 2px;
    }

    /* ===== SRI LANKA BADGE ===== */
    .sri-lanka-badge {
      display: inline-block;
      background: #f5f0eb;
      padding: 4px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      color: #8B1A1A;
      margin-top: 6px;
      letter-spacing: 1px;
      border: 1px solid #e8ddd5;
    }
    .sri-lanka-badge i {
      color: #FF6600;
      margin-right: 4px;
    }

    /* ===== FORM ===== */
    .form-label {
      font-weight: 600;
      font-size: 14px;
      color: #4a3a32;
      margin-bottom: 4px;
    }
    .form-control {
      border-radius: 10px;
      border: 2px solid #eddfd7;
      padding: 12px 16px;
      font-size: 14px;
      background: #fcf9f7;
      transition: all 0.3s ease;
    }
    .form-control:focus {
      border-color: #8B1A1A;
      box-shadow: 0 0 0 4px rgba(139, 26, 26, 0.1);
      background: white;
    }
    .input-group-text {
      background: #fcf9f7;
      border: 2px solid #eddfd7;
      border-right: none;
      border-radius: 10px 0 0 10px;
      color: #8a7a6e;
    }
    .form-control-with-icon {
      border-radius: 0 10px 10px 0;
      border-left: none;
    }

    /* ===== BUTTON ===== */
    .btn-login {
      background: linear-gradient(135deg, #8B1A1A 0%, #A02020 100%);
      color: white;
      border: none;
      border-radius: 12px;
      padding: 14px;
      width: 100%;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(139, 26, 26, 0.3);
      position: relative;
      overflow: hidden;
    }
    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(139, 26, 26, 0.4);
      background: linear-gradient(135deg, #7a1515 0%, #8B1A1A 100%);
    }
    .btn-login:active {
      transform: translateY(0);
    }
    .btn-login i {
      margin-right: 10px;
    }

    /* ===== LINKS ===== */
    .forgot-link {
      color: #8a7a6e;
      font-size: 13px;
      text-decoration: none;
      transition: color 0.3s;
    }
    .forgot-link:hover {
      color: #8B1A1A;
      text-decoration: underline;
    }

    /* ===== ALERT ===== */
    .alert-danger {
      background: #fdf2ee;
      border-left: 4px solid #8B1A1A;
      color: #8B1A1A;
      border-radius: 10px;
      font-size: 14px;
      padding: 12px 16px;
    }

    /* ===== FOOTER ===== */
    .footer-text {
      text-align: center;
      margin-top: 24px;
      font-size: 12px;
      color: #b5a69a;
      letter-spacing: 0.5px;
    }
    .footer-text i {
      color: #8B1A1A;
    }
    .footer-text .heart {
      color: #CC0000;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      .login-card { padding: 30px 20px; }
      .logo-title { font-size: 22px; }
      .logo-icon { width: 60px; height: 60px; line-height: 60px; font-size: 32px; }
    }
  </style>
</head>
<body>

  <!-- ===== SRI LANKAN STRIPES ===== -->
  <div class="sri-lanka-stripes">
    <div class="stripe stripe-maroon"></div>
    <div class="stripe stripe-gold"></div>
    <div class="stripe stripe-green"></div>
    <div class="stripe stripe-orange"></div>
    <div class="stripe stripe-maroon2"></div>
  </div>

  <!-- ===== LOGIN CARD ===== -->
  <div class="login-card">

    <!-- ===== LOGO ===== -->
    <div class="logo-wrapper">
      <div class="logo-icon">
        <i class="fas fa-bus"></i>
      </div>
      <div class="logo-title">SRM<span>SS</span></div>
      <div class="logo-sub">SMART ROUTE MANAGEMENT</div>
      <div class="sri-lanka-badge">
        <i class="fas fa-map-pin"></i> SRI LANKA
      </div>
    </div>

    <!-- ===== ERROR MESSAGE ===== -->
    <% if (error) { %>
      <div class="alert alert-danger mb-3">
        <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
      </div>
    <% } %>

    <!-- ===== LOGIN FORM ===== -->
    <form action="/login" method="POST">

      <!-- Email -->
      <div class="mb-3">
        <label class="form-label">
          <i class="fas fa-envelope me-2" style="color:#8B1A1A;"></i>Email Address
        </label>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-user" style="color:#8a7a6e;"></i></span>
          <input type="email" name="email" class="form-control form-control-with-icon" 
                 placeholder="Enter your email" required>
        </div>
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label class="form-label">
          <i class="fas fa-lock me-2" style="color:#8B1A1A;"></i>Password
        </label>
        <div class="input-group">
          <span class="input-group-text"><i class="fas fa-key" style="color:#8a7a6e;"></i></span>
          <input type="password" name="password" class="form-control form-control-with-icon" 
                 placeholder="Enter your password" required>
        </div>
      </div>

      <!-- Remember Me & Forgot -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="rememberMe" style="border-color:#8B1A1A;">
          <label class="form-check-label" for="rememberMe" style="font-size:13px; color:#5a4a3a;">
            Remember me
          </label>
        </div>
        <a href="#" class="forgot-link">
          <i class="fas fa-question-circle me-1"></i> Forgot password?
        </a>
      </div>

      <!-- Login Button -->
      <button type="submit" class="btn-login">
        <i class="fas fa-sign-in-alt"></i> LOGIN
      </button>

    </form>

    <!-- ===== FOOTER ===== -->
    <div class="footer-text">
      <i class="fas fa-shield-alt me-1"></i> Secure Login • 
      <span class="heart">❤</span> Made in Sri Lanka
    </div>

  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>