<!DOCTYPE html>
<html>
<head>
  <title>SRMSS — Access Denied</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
</head>
<body style="background:#f5f0eb; display:flex; align-items:center; justify-content:center; height:100vh;">
  <div style="text-align:center; background:white; padding:48px; border-radius:20px; box-shadow:0 8px 32px rgba(139,26,26,0.1); border-top:4px solid #8B1A1A;">
    <i class="fas fa-lock" style="font-size:56px; color:#8B1A1A; margin-bottom:16px; display:block;"></i>
    <h2 style="color:#3a2a22; font-weight:800;">Access Denied</h2>
    <p style="color:#8a7a6e; margin:12px 0 24px;">You don't have permission to access this page.</p>
    <% if(user) { %>
      <p style="font-size:13px; color:#b5a69a; margin-bottom:20px;">
        Logged in as <strong><%= user.full_name %></strong> 
        (<span style="color:#8B1A1A;"><%= user.role %></span>)
      </p>
    <% } %>
    <a href="/dashboard" style="background:#8B1A1A; color:white; padding:10px 28px; border-radius:10px; text-decoration:none; font-weight:600;">
      <i class="fas fa-home me-2"></i>Go to Dashboard
    </a>
  </div>
</body>
</html>