<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SRMSS — Edit Bus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    /* ===== GLOBAL ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #f5f0eb;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* ===== SRI LANKAN STRIPES ===== */
    .sri-lanka-stripes {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 6px;
      display: flex;
      z-index: 1050;
    }
    .stripe { flex: 1; height: 100%; }
    .stripe-maroon { background: #8B1A1A; }
    .stripe-gold { background: #FFD700; }
    .stripe-green { background: #006633; }
    .stripe-orange { background: #FF6600; }
    .stripe-maroon2 { background: #8B1A1A; }

    /* ===== SIDEBAR ===== */
    .sidebar {
      width: 260px;
      height: 100vh;
      background: linear-gradient(180deg, #8B1A1A 0%, #6B1010 100%);
      position: fixed;
      top: 6px;
      left: 0;
      padding: 20px 0;
      color: white;
      z-index: 1040;
      overflow-y: auto;
      box-shadow: 4px 0 20px rgba(139, 26, 26, 0.2);
      transition: all 0.3s ease;
    }
    .sidebar-brand {
      font-size: 22px;
      font-weight: 800;
      padding: 0 20px 18px 20px;
      border-bottom: 2px solid rgba(255, 215, 0, 0.3);
      display: flex;
      align-items: center;
      gap: 10px;
      color: #FFD700;
    }
    .sidebar-brand span { color: white; }
    .sidebar-brand i { font-size: 28px; }
    .sidebar-section {
      padding: 12px 20px 6px 20px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.4);
    }
    .sidebar a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 20px;
      color: rgba(255, 255, 255, 0.75);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.3s ease;
      border-left: 3px solid transparent;
    }
    .sidebar a i { width: 20px; text-align: center; font-size: 16px; }
    .sidebar a:hover {
      background: rgba(255, 215, 0, 0.12);
      color: white;
      border-left-color: #FFD700;
    }
    .sidebar a.active {
      background: rgba(255, 215, 0, 0.15);
      color: #FFD700;
      border-left-color: #FFD700;
    }
    .sidebar a.logout-link {
      margin-top: 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 16px;
      color: rgba(255, 150, 150, 0.8);
    }
    .sidebar a.logout-link:hover { color: #ff6b6b; border-left-color: #ff6b6b; }
    .sidebar .sri-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 8px 16px;
      margin: 12px 16px 0 16px;
      background: rgba(255, 215, 0, 0.15);
      border-radius: 20px;
      font-size: 11px;
      color: #FFD700;
      border: 1px solid rgba(255, 215, 0, 0.2);
    }

    /* ===== MAIN CONTENT ===== */
    .main {
      margin-left: 260px;
      padding: 30px 30px 30px 30px;
      margin-top: 6px;
    }

    /* ===== TOPBAR ===== */
    .topbar {
      background: white;
      padding: 16px 24px;
      border-radius: 16px;
      margin-bottom: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 4px 20px rgba(139, 26, 26, 0.08);
      border-left: 4px solid #8B1A1A;
    }
    .topbar h5 {
      font-weight: 700;
      color: #3a2a22;
    }
    .topbar h5 i { color: #8B1A1A; margin-right: 8px; }
    .topbar .user-info {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .topbar .user-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #8B1A1A, #A02020);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
    }

    /* ===== CARD ===== */
    .card-custom {
      background: white;
      border-radius: 16px;
      padding: 32px;
      box-shadow: 0 4px 20px rgba(139, 26, 26, 0.06);
      border: none;
      border-top: 4px solid #8B1A1A;
    }
    .card-custom .card-title {
      font-weight: 700;
      color: #3a2a22;
      margin-bottom: 24px;
      padding-bottom: 12px;
      border-bottom: 2px solid #f5f0eb;
    }
    .card-custom .card-title i { color: #8B1A1A; margin-right: 10px; }
    .card-custom .bus-code-badge {
      background: #fdf2ee;
      color: #8B1A1A;
      padding: 4px 16px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }

    .form-label {
      font-weight: 600;
      font-size: 13px;
      color: #4a3a32;
      margin-bottom: 4px;
    }
    .form-label i { color: #8B1A1A; margin-right: 6px; width: 16px; }

    .form-control, .form-select {
      border-radius: 10px;
      border: 2px solid #eddfd7;
      padding: 10px 14px;
      font-size: 14px;
      background: #fcf9f7;
      transition: all 0.3s ease;
    }
    .form-control:focus, .form-select:focus {
      border-color: #8B1A1A;
      box-shadow: 0 0 0 4px rgba(139, 26, 26, 0.1);
      background: white;
    }
    .form-control[readonly] {
      background: #f5f0eb;
      cursor: not-allowed;
    }

    .btn-warning {
      background: linear-gradient(135deg, #FFD700 0%, #F0C000 100%);
      color: #3a2a22;
      border: none;
      border-radius: 10px;
      padding: 10px 28px;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(255, 215, 0, 0.3);
    }
    .btn-warning:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(255, 215, 0, 0.4);
    }
    .btn-warning i { margin-right: 8px; }

    .btn-primary {
      background: linear-gradient(135deg, #8B1A1A 0%, #A02020 100%);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 10px 28px;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(139, 26, 26, 0.25);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(139, 26, 26, 0.35);
      background: linear-gradient(135deg, #7a1515 0%, #8B1A1A 100%);
    }
    .btn-primary i { margin-right: 8px; }

    .btn-outline-secondary {
      border-radius: 10px;
      border: 2px solid #eddfd7;
      color: #5a4a3a;
      padding: 10px 28px;
      font-weight: 500;
      transition: all 0.3s ease;
    }
    .btn-outline-secondary:hover {
      border-color: #8B1A1A;
      background: #fdf2ee;
      color: #8B1A1A;
    }

    .btn-danger {
      background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 10px 28px;
      font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(220, 53, 69, 0.25);
    }
    .btn-danger:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(220, 53, 69, 0.35);
    }
    .btn-danger i { margin-right: 8px; }

    .required-star { color: #8B1A1A; font-weight: 700; margin-left: 2px; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .sidebar {
        width: 72px;
        padding: 12px 0;
      }
      .sidebar-brand {
        font-size: 16px;
        padding: 0 12px 12px 12px;
        justify-content: center;
      }
      .sidebar-brand span,
      .sidebar-brand .brand-text,
      .sidebar-section,
      .sidebar a span,
      .sidebar .sri-badge {
        display: none;
      }
      .sidebar a {
        justify-content: center;
        padding: 14px 0;
      }
      .sidebar a i {
        font-size: 20px;
        margin: 0;
      }
      .main {
        margin-left: 72px;
        padding: 20px 16px;
      }
      .topbar {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .card-custom { padding: 20px; }
      .btn-group-responsive {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .btn-group-responsive .btn {
        flex: 1;
        min-width: 100px;
      }
    }
  </style>
</head>
<body>

  <!-- ===== SRI LANKAN STRIPES ===== -->
  <div class="sri-lanka-stripes">
    <div class="stripe stripe-maroon"></div>
    <div class="stripe stripe-gold"></div>
    <div class="stripe stripe-green"></div>
    <div class="stripe stripe-orange"></div>
    <div class="stripe stripe-maroon2"></div>
  </div>

  <!-- ===== SIDEBAR ===== -->
  <div class="sidebar">
    <div class="sidebar-brand">
      <i class="fas fa-bus"></i>
      <span>SRM<span class="brand-text">SS</span></span>
    </div>

    <div class="sidebar-section">Main Menu</div>
    <a href="/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
    <a href="/routes"><i class="fas fa-route"></i><span>Routes</span></a>
    <a href="/schedules"><i class="fas fa-calendar-alt"></i><span>Schedules</span></a>

    <div class="sidebar-section">Management</div>
    <a href="/buses" class="active"><i class="fas fa-bus-alt"></i><span>Buses</span></a>
    <a href="/drivers"><i class="fas fa-id-card"></i><span>Drivers</span></a>
    <a href="/fuel"><i class="fas fa-gas-pump"></i><span>Fuel Logs</span></a>
    <a href="/maintenance"><i class="fas fa-wrench"></i><span>Maintenance</span></a>

    <div class="sidebar-section">Analytics</div>
    <a href="/reports"><i class="fas fa-file-alt"></i><span>Reports</span></a>
    <a href="/users"><i class="fas fa-users"></i><span>Users</span></a>

    <a href="/logout" class="logout-link">
      <i class="fas fa-sign-out-alt"></i><span>Logout</span>
    </a>

    <div class="sri-badge">
      <i class="fas fa-flag"></i> Sri Lanka
      <i class="fas fa-map-pin" style="font-size:10px;"></i>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="main">

    <!-- Topbar -->
    <div class="topbar">
      <h5>
        <i class="fas fa-pen-to-square"></i> Edit Bus
        <span class="bus-code-badge ms-2">
          <i class="fas fa-hashtag me-1"></i> <%= bus.registration_no %>
        </span>
      </h5>
      <div class="user-info">
        <div class="user-avatar">
          <%= user ? user.full_name.charAt(0).toUpperCase() : 'A' %>
        </div>
        <span style="font-weight:600; color:#3a2a22;">
          <%= user ? user.full_name : 'Admin' %>
        </span>
      </div>
    </div>

    <!-- ===== EDIT BUS FORM ===== -->
    <div class="card-custom">
      <div class="card-title">
        <i class="fas fa-bus-alt"></i> Bus Details
        <span style="font-size:12px; color:#8a7a6e; font-weight:400; margin-left:12px;">
          <i class="fas fa-asterisk" style="color:#8B1A1A; font-size:8px;"></i> Required fields
        </span>
      </div>

      <% if(error) { %>
        <div class="alert alert-danger" style="border-radius:10px; border-left:4px solid #8B1A1A; background:#fdf2ee; color:#8B1A1A;">
          <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
        </div>
      <% } %>

      <% if(success) { %>
        <div class="alert alert-success" style="border-radius:10px; border-left:4px solid #006633; background:#e8f5ee; color:#006633;">
          <i class="fas fa-check-circle me-2"></i> <%= success %>
        </div>
      <% } %>

      <form action="/buses/edit/<%= bus.bus_id %>" method="POST">
        <div class="row g-4">

          <!-- Registration No -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-hashtag"></i> Registration No
              <span class="required-star">*</span>
            </label>
            <input type="text" name="registration_no" class="form-control" 
                   value="<%= bus.registration_no %>" required>
          </div>

          <!-- Model -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-car"></i> Model
            </label>
            <input type="text" name="model" class="form-control" 
                   value="<%= bus.model || '' %>" placeholder="e.g. Toyota Hino">
          </div>

          <!-- Seating Capacity -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-chair"></i> Seating Capacity
              <span class="required-star">*</span>
            </label>
            <input type="number" name="seating_capacity" class="form-control" 
                   value="<%= bus.seating_capacity %>" required>
          </div>

          <!-- Mileage -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-road"></i> Mileage (km)
            </label>
            <input type="number" name="mileage_km" class="form-control" 
                   value="<%= bus.mileage_km || 0 %>" step="0.01">
          </div>

          <!-- Fuel Type -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-gas-pump"></i> Fuel Type
            </label>
            <select name="fuel_type" class="form-select">
              <option value="diesel" <%= bus.fuel_type === 'diesel' ? 'selected' : '' %>>⛽ Diesel</option>
              <option value="petrol" <%= bus.fuel_type === 'petrol' ? 'selected' : '' %>>⛽ Petrol</option>
              <option value="electric" <%= bus.fuel_type === 'electric' ? 'selected' : '' %>>⚡ Electric</option>
              <option value="hybrid" <%= bus.fuel_type === 'hybrid' ? 'selected' : '' %>>🔋 Hybrid</option>
            </select>
          </div>

          <!-- Status -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-circle"></i> Status
            </label>
            <select name="status" class="form-select">
              <option value="available" <%= bus.status === 'available' ? 'selected' : '' %>>🟢 Available</option>
              <option value="on_route" <%= bus.status === 'on_route' ? 'selected' : '' %>>🟠 On Route</option>
              <option value="maintenance" <%= bus.status === 'maintenance' ? 'selected' : '' %>>🔴 Maintenance</option>
              <option value="inactive" <%= bus.status === 'inactive' ? 'selected' : '' %>>⚪ Inactive</option>
            </select>
          </div>

          <!-- Created At (Read-only) -->
          <div class="col-md-6">
            <label class="form-label">
              <i class="fas fa-calendar-plus"></i> Created
            </label>
            <input type="text" class="form-control" readonly
                   value="<%= bus.created_at ? new Date(bus.created_at).toLocaleString('en-LK', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'N/A' %>">
          </div>

        </div>

        <!-- Buttons -->
        <div class="mt-4 pt-2" style="border-top: 2px solid #f5f0eb;">
          <div class="btn-group-responsive">
            <button type="submit" class="btn btn-warning">
              <i class="fas fa-save"></i> Update Bus
            </button>
            <a href="/buses" class="btn btn-outline-secondary">
              <i class="fas fa-times"></i> Cancel
            </a>
            <a href="/buses/delete/<%= bus.bus_id %>" class="btn btn-danger" 
               onclick="return confirm('Are you sure you want to delete this bus?')">
              <i class="fas fa-trash"></i> Delete
            </a>
          </div>
        </div>
      </form>
    </div>

    <!-- ===== FOOTER ===== -->
    <div class="text-center mt-4" style="font-size:12px; color:#b5a69a;">
      <i class="fas fa-shield-alt me-1"></i> SRMSS v1.0 •
      <i class="fas fa-heart" style="color:#8B1A1A;"></i> Made in Sri Lanka
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>