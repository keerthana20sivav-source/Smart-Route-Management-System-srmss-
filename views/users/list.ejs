<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SRMSS — Users</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    /* ===== GLOBAL ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #f5f0eb;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* ===== SRI LANKAN STRIPES ===== */
    .sri-lanka-stripes {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 6px;
      display: flex;
      z-index: 1050;
    }
    .stripe { flex: 1; height: 100%; }
    .stripe-maroon { background: #8B1A1A; }
    .stripe-gold { background: #FFD700; }
    .stripe-green { background: #006633; }
    .stripe-orange { background: #FF6600; }
    .stripe-maroon2 { background: #8B1A1A; }

    /* ===== SIDEBAR ===== */
    .sidebar {
      width: 260px;
      height: 100vh;
      background: linear-gradient(180deg, #8B1A1A 0%, #6B1010 100%);
      position: fixed;
      top: 6px;
      left: 0;
      padding: 20px 0;
      color: white;
      z-index: 1040;
      overflow-y: auto;
      box-shadow: 4px 0 20px rgba(139, 26, 26, 0.2);
      transition: all 0.3s ease;
    }
    .sidebar-brand {
      font-size: 22px;
      font-weight: 800;
      padding: 0 20px 18px 20px;
      border-bottom: 2px solid rgba(255, 215, 0, 0.3);
      display: flex;
      align-items: center;
      gap: 10px;
      color: #FFD700;
    }
    .sidebar-brand span { color: white; }
    .sidebar-brand i { font-size: 28px; }
    .sidebar-section {
      padding: 12px 20px 6px 20px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: rgba(255, 255, 255, 0.4);
    }
    .sidebar a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 20px;
      color: rgba(255, 255, 255, 0.75);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.3s ease;
      border-left: 3px solid transparent;
    }
    .sidebar a i { width: 20px; text-align: center; font-size: 16px; }
    .sidebar a:hover {
      background: rgba(255, 215, 0, 0.12);
      color: white;
      border-left-color: #FFD700;
    }
    .sidebar a.active {
      background: rgba(255, 215, 0, 0.15);
      color: #FFD700;
      border-left-color: #FFD700;
    }
    .sidebar a.logout-link {
      margin-top: 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 16px;
      color: rgba(255, 150, 150, 0.8);
    }
    .sidebar a.logout-link:hover { color: #ff6b6b; border-left-color: #ff6b6b; }
    .sidebar .sri-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 8px 16px;
      margin: 12px 16px 0 16px;
      background: rgba(255, 215, 0, 0.15);
      border-radius: 20px;
      font-size: 11px;
      color: #FFD700;
      border: 1px solid rgba(255, 215, 0, 0.2);
    }

    /* ===== MAIN CONTENT ===== */
    .main {
      margin-left: 260px;
      padding: 30px 30px 30px 30px;
      margin-top: 6px;
    }

    /* ===== TOPBAR ===== */
    .topbar {
      background: white;
      padding: 16px 24px;
      border-radius: 16px;
      margin-bottom: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 4px 20px rgba(139, 26, 26, 0.08);
      border-left: 4px solid #8B1A1A;
    }
    .topbar h5 {
      font-weight: 700;
      color: #3a2a22;
    }
    .topbar h5 i { color: #8B1A1A; margin-right: 8px; }
    .topbar .user-info {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .topbar .user-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #8B1A1A, #A02020);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
    }

    /* ===== STATS BADGE ===== */
    .stats-badge {
      background: #fdf2ee;
      color: #8B1A1A;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }

    /* ===== BUTTONS ===== */
    .btn-add {
      background: linear-gradient(135deg, #8B1A1A 0%, #A02020 100%);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 8px 20px;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 16px rgba(139, 26, 26, 0.2);
    }
    .btn-add:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(139, 26, 26, 0.3);
      background: linear-gradient(135deg, #7a1515 0%, #8B1A1A 100%);
      color: white;
    }
    .btn-add i { margin-right: 6px; }

    .btn-sm-outline {
      border-radius: 8px;
      padding: 4px 10px;
      font-size: 13px;
      border: 2px solid #eddfd7;
      background: transparent;
      transition: all 0.3s ease;
    }
    .btn-sm-outline.delete {
      color: #dc3545;
    }
    .btn-sm-outline.delete:hover {
      background: #fdf2ee;
      border-color: #dc3545;
    }
    .btn-sm-outline.edit {
      color: #8B1A1A;
    }
    .btn-sm-outline.edit:hover {
      background: #fdf2ee;
      border-color: #8B1A1A;
    }

    /* ===== CARD / TABLE ===== */
    .card-custom {
      background: white;
      border-radius: 16px;
      padding: 0;
      box-shadow: 0 4px 20px rgba(139, 26, 26, 0.06);
      border: none;
      border-top: 4px solid #8B1A1A;
      overflow: hidden;
    }
    .card-custom .card-header-custom {
      padding: 18px 24px;
      background: #faf7f5;
      border-bottom: 2px solid #f5f0eb;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .card-custom .card-header-custom h6 {
      font-weight: 700;
      color: #3a2a22;
      margin: 0;
    }
    .card-custom .card-header-custom h6 i {
      color: #8B1A1A;
      margin-right: 8px;
    }

    .table {
      margin-bottom: 0;
    }
    .table thead th {
      background: #faf7f5;
      color: #5a4a3a;
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 2px solid #f5f0eb;
      padding: 12px 16px;
      white-space: nowrap;
    }
    .table tbody td {
      padding: 12px 16px;
      vertical-align: middle;
      font-size: 13px;
      border-bottom: 1px solid #f5f0eb;
      color: #3a2a22;
    }
    .table tbody tr:hover {
      background: #fdfaf8;
    }
    .table tbody tr:last-child td {
      border-bottom: none;
    }

    .empty-state {
      padding: 40px 20px;
      text-align: center;
      color: #b5a69a;
    }
    .empty-state i {
      font-size: 48px;
      margin-bottom: 12px;
      display: block;
      color: #eddfd7;
    }
    .empty-state h6 {
      color: #3a2a22;
      font-weight: 600;
    }

    /* ===== AVATAR ===== */
    .avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, #8B1A1A, #A02020);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 15px;
      flex-shrink: 0;
    }
    .avatar-sm {
      width: 32px;
      height: 32px;
      font-size: 13px;
    }

    /* ===== BADGES ===== */
    .badge-admin {
      background: #fdf2ee;
      color: #8B1A1A;
      padding: 4px 14px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 12px;
    }
    .badge-supervisor {
      background: #fdf0e6;
      color: #FF6600;
      padding: 4px 14px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 12px;
    }
    .badge-staff {
      background: #f5f0eb;
      color: #5a4a3a;
      padding: 4px 14px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 12px;
    }

    .badge-active {
      background: #e8f5ee;
      color: #006633;
      padding: 4px 14px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 12px;
    }
    .badge-inactive {
      background: #f5f0eb;
      color: #8a7a6e;
      padding: 4px 14px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 12px;
    }

    .user-icon { color: #8B1A1A; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .sidebar {
        width: 72px;
        padding: 12px 0;
      }
      .sidebar-brand {
        font-size: 16px;
        padding: 0 12px 12px 12px;
        justify-content: center;
      }
      .sidebar-brand span,
      .sidebar-brand .brand-text,
      .sidebar-section,
      .sidebar a span,
      .sidebar .sri-badge {
        display: none;
      }
      .sidebar a {
        justify-content: center;
        padding: 14px 0;
      }
      .sidebar a i {
        font-size: 20px;
        margin: 0;
      }
      .main {
        margin-left: 72px;
        padding: 20px 16px;
      }
      .topbar {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .card-custom .card-header-custom {
        flex-direction: column;
        gap: 8px;
        align-items: flex-start;
      }
      .table-responsive-wrapper {
        overflow-x: auto;
      }
    }
  </style>
</head>
<body>

  <!-- ===== SRI LANKAN STRIPES ===== -->
  <div class="sri-lanka-stripes">
    <div class="stripe stripe-maroon"></div>
    <div class="stripe stripe-gold"></div>
    <div class="stripe stripe-green"></div>
    <div class="stripe stripe-orange"></div>
    <div class="stripe stripe-maroon2"></div>
  </div>

  <!-- ===== SIDEBAR ===== -->
  <div class="sidebar">
    <div class="sidebar-brand">
      <i class="fas fa-bus"></i>
      <span>SRM<span class="brand-text">SS</span></span>
    </div>

    <div class="sidebar-section">Main Menu</div>
    <a href="/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
    <a href="/routes"><i class="fas fa-route"></i><span>Routes</span></a>
    <a href="/schedules"><i class="fas fa-calendar-alt"></i><span>Schedules</span></a>

    <div class="sidebar-section">Management</div>
    <a href="/buses"><i class="fas fa-bus-alt"></i><span>Buses</span></a>
    <a href="/drivers"><i class="fas fa-id-card"></i><span>Drivers</span></a>
    <a href="/fuel"><i class="fas fa-gas-pump"></i><span>Fuel Logs</span></a>
    <a href="/maintenance"><i class="fas fa-wrench"></i><span>Maintenance</span></a>

    <div class="sidebar-section">Analytics</div>
    <a href="/reports"><i class="fas fa-file-alt"></i><span>Reports</span></a>
    <a href="/users" class="active"><i class="fas fa-users"></i><span>Users</span></a>

    <a href="/logout" class="logout-link">
      <i class="fas fa-sign-out-alt"></i><span>Logout</span>
    </a>

    <div class="sri-badge">
      <i class="fas fa-flag"></i> Sri Lanka
      <i class="fas fa-map-pin" style="font-size:10px;"></i>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="main">

    <!-- Topbar -->
    <div class="topbar">
      <h5>
        <i class="fas fa-users"></i> User Management
        <span class="stats-badge ms-2">
          <i class="fas fa-list me-1"></i> <%= users.length %> Users
        </span>
      </h5>
      <div class="d-flex align-items-center gap-3">
        <div class="user-info">
          <div class="user-avatar">
            <%= user ? user.full_name.charAt(0).toUpperCase() : 'A' %>
          </div>
          <span style="font-weight:600; color:#3a2a22;">
            <%= user ? user.full_name : 'Admin' %>
          </span>
        </div>
        <a href="/users/add" class="btn-add btn">
          <i class="fas fa-plus-circle"></i> Add User
        </a>
      </div>
    </div>

    <!-- ===== USERS TABLE ===== -->
    <div class="card-custom">
      <div class="card-header-custom">
        <h6>
          <i class="fas fa-table"></i> All Users
        </h6>
        <div style="font-size:12px; color:#8a7a6e;">
          <i class="fas fa-circle" style="color:#8B1A1A; font-size:8px;"></i> Admin
          <span class="mx-2">|</span>
          <i class="fas fa-circle" style="color:#FF6600; font-size:8px;"></i> Supervisor
          <span class="mx-2">|</span>
          <i class="fas fa-circle" style="color:#5a4a3a; font-size:8px;"></i> Staff
        </div>
      </div>

      <div class="table-responsive-wrapper" style="padding: 0 4px 4px 4px;">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>#</th>
              <th>User</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Created</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if(users.length === 0) { %>
              <tr>
                <td colspan="7">
                  <div class="empty-state">
                    <i class="fas fa-users"></i>
                    <h6>No Users Found</h6>
                    <p style="color:#b5a69a; font-size:14px;">Click "Add User" to create your first user.</p>
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% users.forEach((u, index) => { %>
              <tr>
                <td><strong><%= index + 1 %></strong></td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="avatar">
                      <%= u.full_name ? u.full_name.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <span style="font-weight:600; color:#3a2a22;">
                      <%= u.full_name || 'Unknown' %>
                    </span>
                    <% if(u.user_id === user.user_id) { %>
                      <span style="background:#fdf2ee; color:#8B1A1A; padding:1px 10px; border-radius:12px; font-size:10px; font-weight:600;">
                        <i class="fas fa-user-check"></i> You
                      </span>
                    <% } %>
                  </div>
                </td>
                <td>
                  <span style="background:#faf7f5; padding:2px 12px; border-radius:12px; font-size:12px;">
                    <i class="fas fa-envelope" style="color:#8B1A1A;"></i> <%= u.email %>
                  </span>
                </td>
                <td>
                  <% if(u.role === 'admin') { %>
                    <span class="badge-admin">
                      <i class="fas fa-crown"></i> Admin
                    </span>
                  <% } else if(u.role === 'supervisor') { %>
                    <span class="badge-supervisor">
                      <i class="fas fa-user-tie"></i> Supervisor
                    </span>
                  <% } else { %>
                    <span class="badge-staff">
                      <i class="fas fa-user"></i> Staff
                    </span>
                  <% } %>
                </td>
                <td>
                  <% if(u.status === 'active') { %>
                    <span class="badge-active">
                      <i class="fas fa-circle" style="font-size:8px;"></i> Active
                    </span>
                  <% } else { %>
                    <span class="badge-inactive">
                      <i class="fas fa-circle" style="font-size:8px;"></i> Inactive
                    </span>
                  <% } %>
                </td>
                <td>
                  <i class="fas fa-calendar" style="color:#8B1A1A; font-size:11px;"></i>
                  <%= u.created_at ? new Date(u.created_at).toLocaleDateString('en-LK', { year: 'numeric', month: 'short', day: 'numeric' }) : 'N/A' %>
                </td>
                <td class="text-center">
                  <% if(u.user_id !== user.user_id) { %>
                    <a href="/users/edit/<%= u.user_id %>" 
                       class="btn-sm-outline edit me-1" 
                       title="Edit User">
                      <i class="fas fa-pen"></i>
                    </a>
                    <a href="/users/delete/<%= u.user_id %>" 
                       class="btn-sm-outline delete" 
                       onclick="return confirm('Are you sure you want to delete this user?')"
                       title="Delete User">
                      <i class="fas fa-trash"></i>
                    </a>
                  <% } else { %>
                    <span style="color:#b5a69a; font-size:12px;">
                      <i class="fas fa-lock"></i> Self
                    </span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ===== FOOTER ===== -->
    <div class="text-center mt-4" style="font-size:12px; color:#b5a69a;">
      <i class="fas fa-shield-alt me-1"></i> SRMSS v1.0 •
      <i class="fas fa-heart" style="color:#8B1A1A;"></i> Made in Sri Lanka
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>