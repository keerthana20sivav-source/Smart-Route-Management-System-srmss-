<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SRMSS — Driver Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #f5f0eb; font-family: 'Segoe UI', sans-serif; }
    .sri-lanka-stripes { position: fixed; top: 0; left: 0; width: 100%; height: 6px; display: flex; z-index: 1050; }
    .stripe { flex: 1; height: 100%; }
    .stripe-maroon { background: #8B1A1A; } .stripe-gold { background: #FFD700; } .stripe-green { background: #006633; } .stripe-orange { background: #FF6600; }
    .sidebar { width: 260px; height: 100vh; background: linear-gradient(180deg, #8B1A1A 0%, #6B1010 100%); position: fixed; top: 6px; left: 0; padding: 20px 0; color: white; z-index: 1040; overflow-y: auto; box-shadow: 4px 0 20px rgba(139,26,26,0.2); }
    .sidebar-brand { font-size: 22px; font-weight: 800; padding: 0 20px 18px 20px; border-bottom: 2px solid rgba(255,215,0,0.3); display: flex; align-items: center; gap: 10px; color: #FFD700; }
    .sidebar-section { padding: 12px 20px 6px 20px; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255,255,255,0.4); }
    .sidebar a { display: flex; align-items: center; gap: 12px; padding: 11px 20px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 14px; font-weight: 500; border-left: 3px solid transparent; }
    .sidebar a:hover, .sidebar a.active { background: rgba(255,215,0,0.15); color: #FFD700; border-left-color: #FFD700; }
    .sidebar a.logout-link { margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; color: rgba(255,150,150,0.8); }
    .sidebar .sri-badge { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px 16px; margin: 12px 16px 0 16px; background: rgba(255,215,0,0.15); border-radius: 20px; font-size: 11px; color: #FFD700; }
    .main { margin-left: 260px; padding: 30px; margin-top: 6px; }
    .topbar { background: white; padding: 16px 24px; border-radius: 16px; margin-bottom: 28px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 20px rgba(139,26,26,0.08); border-left: 4px solid #8B1A1A; }
    .topbar h5 { font-weight: 700; color: #3a2a22; }
    .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #8B1A1A, #A02020); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; }
    .card-custom { background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(139,26,26,0.06); border-top: 4px solid #8B1A1A; margin-bottom: 24px; }
    .stat-mini { background: #faf7f5; border-radius: 12px; padding: 16px; text-align: center; }
    .stat-mini .val { font-size: 24px; font-weight: 800; color: #8B1A1A; }
    .stat-mini .lbl { font-size: 12px; color: #8a7a6e; }
    .table thead th { background: #faf7f5; color: #5a4a3a; font-weight: 600; font-size: 12px; text-transform: uppercase; padding: 12px 16px; }
    .table tbody td { padding: 12px 16px; font-size: 13px; border-bottom: 1px solid #f5f0eb; vertical-align: middle; }
    .badge-scheduled { background: #e8f5ee; color: #006633; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-cancelled { background: #fdf2ee; color: #8B1A1A; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-emergency { background: #fff3cd; color: #856404; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-completed { background: #e8f0fe; color: #1a56db; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .driver-avatar { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, #8B1A1A, #A02020); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 28px; }
  </style>
</head>
<body>

  <div class="sri-lanka-stripes">
    <div class="stripe stripe-maroon"></div><div class="stripe stripe-gold"></div>
    <div class="stripe stripe-green"></div><div class="stripe stripe-orange"></div>
    <div class="stripe stripe-maroon"></div>
  </div>

  <div class="sidebar">
    <div class="sidebar-brand"><i class="fas fa-bus"></i><span>SRMSS</span></div>
    <div class="sidebar-section">Main Menu</div>
    <a href="/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
    <a href="/routes"><i class="fas fa-route"></i><span>Routes</span></a>
    <a href="/schedules"><i class="fas fa-calendar-alt"></i><span>Schedules</span></a>
    <a href="/routes/map"><i class="fas fa-map"></i><span>Map View</span></a>
    <div class="sidebar-section">Management</div>
    <a href="/buses"><i class="fas fa-bus-alt"></i><span>Buses</span></a>
    <a href="/drivers" class="active"><i class="fas fa-id-card"></i><span>Drivers</span></a>
    <a href="/fuel"><i class="fas fa-gas-pump"></i><span>Fuel Logs</span></a>
    <a href="/maintenance"><i class="fas fa-wrench"></i><span>Maintenance</span></a>
    <div class="sidebar-section">Analytics</div>
    <a href="/reports"><i class="fas fa-file-alt"></i><span>Reports</span></a>
    <a href="/users"><i class="fas fa-users"></i><span>Users</span></a>
    <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
    <div class="sri-badge"><i class="fas fa-flag"></i>Sri Lanka</div>
  </div>

  <div class="main">
    <div class="topbar">
      <h5><i class="fas fa-id-card" style="color:#8B1A1A; margin-right:8px;"></i>Driver Profile</h5>
      <div class="d-flex align-items-center gap-2">
        <div class="user-avatar"><%= user.full_name.charAt(0).toUpperCase() %></div>
        <a href="/drivers" class="btn btn-outline-secondary btn-sm" style="border-radius:10px; border:2px solid #eddfd7;">
          <i class="fas fa-arrow-left me-1"></i>Back
        </a>
        <a href="/drivers/edit/<%= driver.driver_id %>" class="btn btn-sm" style="background:#8B1A1A; color:white; border-radius:10px; padding:6px 16px;">
          <i class="fas fa-pen me-1"></i>Edit
        </a>
      </div>
    </div>

    <!-- Driver Info -->
    <div class="card-custom">
      <div class="d-flex align-items-center gap-4 mb-4">
        <div class="driver-avatar"><%= driver.full_name.charAt(0).toUpperCase() %></div>
        <div>
          <h4 style="font-weight:800; color:#3a2a22; margin:0;"><%= driver.full_name %></h4>
          <span style="color:#8a7a6e; font-size:14px;">
            <i class="fas fa-id-card me-1" style="color:#8B1A1A;"></i><%= driver.license_no %>
          </span>
          <span style="margin-left:12px; background:<%= driver.status === 'available' ? '#e8f5ee' : '#fdf2ee' %>; color:<%= driver.status === 'available' ? '#006633' : '#8B1A1A' %>; padding:3px 14px; border-radius:20px; font-size:12px; font-weight:600;">
            <%= driver.status %>
          </span>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-3">
          <div class="stat-mini">
            <div class="val"><%= schedules.length %></div>
            <div class="lbl">Total Trips</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-mini">
            <div class="val"><%= stats.total_trips || 0 %></div>
            <div class="lbl">Trips This Month</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-mini">
            <div class="val"><%= stats.total_hours || 0 %> hrs</div>
            <div class="lbl">Hours This Month</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="stat-mini">
            <div class="val"><i class="fas fa-map-pin" style="font-size:18px;"></i></div>
            <div class="lbl"><%= driver.current_location || 'Colombo' %></div>
          </div>
        </div>
      </div>

      <div class="row g-3 mt-2">
        <div class="col-md-4">
          <small style="color:#8a7a6e;">Phone</small>
          <div style="font-weight:600;"><i class="fas fa-phone me-1" style="color:#8B1A1A;"></i><%= driver.phone || 'N/A' %></div>
        </div>
        <div class="col-md-4">
          <small style="color:#8a7a6e;">License Expiry</small>
          <div style="font-weight:600; color:<%= new Date(driver.license_expiry) < new Date() ? '#dc3545' : '#006633' %>;">
            <i class="fas fa-calendar me-1"></i>
            <%= driver.license_expiry ? new Date(driver.license_expiry).toLocaleDateString() : 'N/A' %>
          </div>
        </div>
        <div class="col-md-4">
          <small style="color:#8a7a6e;">Working Hours/Day</small>
          <div style="font-weight:600;"><i class="fas fa-clock me-1" style="color:#8B1A1A;"></i><%= driver.working_hours || 0 %> hrs</div>
        </div>
      </div>
    </div>

    <!-- Assigned Routes / Schedules -->
    <div class="card-custom">
      <h6 style="font-weight:700; color:#3a2a22; margin-bottom:16px;">
        <i class="fas fa-route me-2" style="color:#8B1A1A;"></i>Assigned Routes & Schedules
        <span style="background:#fdf2ee; color:#8B1A1A; padding:3px 14px; border-radius:20px; font-size:12px; font-weight:600; margin-left:8px;">
          <%= schedules.length %> total
        </span>
      </h6>

      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>#</th>
              <th>Route</th>
              <th>Bus</th>
              <th>Departure</th>
              <th>Arrival</th>
              <th>Distance</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if(schedules.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted py-4">
                <i class="fas fa-route" style="font-size:32px; color:#eddfd7; display:block; margin-bottom:8px;"></i>
                No routes assigned yet
              </td></tr>
            <% } else { %>
              <% schedules.forEach((s, i) => { %>
                <tr>
                  <td><strong><%= i + 1 %></strong></td>
                  <td>
                    <span style="font-weight:600;"><i class="fas fa-route" style="color:#8B1A1A;"></i> <%= s.route_name || 'N/A' %></span>
                    <br><small style="color:#8a7a6e;"><%= s.start_point %> → <%= s.end_point %></small>
                  </td>
                  <td><span style="background:#faf7f5; padding:2px 10px; border-radius:10px; font-size:12px;"><i class="fas fa-bus-alt" style="color:#8B1A1A;"></i> <%= s.registration_no || 'N/A' %></span></td>
                  <td style="font-size:12px;"><%= s.departure_time ? new Date(s.departure_time).toLocaleString() : 'N/A' %></td>
                  <td style="font-size:12px;"><%= s.arrival_time ? new Date(s.arrival_time).toLocaleString() : 'N/A' %></td>
                  <td><%= s.distance_km ? s.distance_km + ' km' : 'N/A' %></td>
                  <td>
                    <% if(s.status === 'scheduled') { %><span class="badge-scheduled">Scheduled</span>
                    <% } else if(s.status === 'cancelled') { %><span class="badge-cancelled">Cancelled</span>
                    <% } else if(s.status === 'emergency') { %><span class="badge-emergency">Emergency</span>
                    <% } else { %><span class="badge-completed">Completed</span><% } %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="text-center mt-4" style="font-size:12px; color:#b5a69a;">
      <i class="fas fa-shield-alt me-1"></i> SRMSS v1.0 • <i class="fas fa-heart" style="color:#8B1A1A;"></i> Made in Sri Lanka
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>